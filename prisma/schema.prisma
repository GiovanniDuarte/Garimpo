generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./garimpo.db"
}

model Canal {
  id                 String    @id @default(cuid())
  nome               String
  url                String    @unique
  youtubeId          String    @unique
  inscritos          Int?
  totalViews         Int?
  videosPublicados   Int?
  dataCriacaoCanal   DateTime?
  ultimaAtividade    DateTime?
  frequenciaPostagem String?
  nichoInferido      String?
  idiomaPrincipal    String?
  descricao          String?
  gemScore           Float?
  gemScoreDetalhado  String?
  status             String    @default("novo")
  categorias         String?
  tags               String?
  notas              String?
  thumbnailUrl       String?
  avatarLocal        String?
  pais               String?
  mochilaAt          DateTime?
  mochilaVideoCount  Int?
  favorito           Boolean   @default(false)
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  videos             Video[]
  analise            AnaliseDNA?
  projetos           Projeto[]
  cacadaDescobertas  CacadaDescoberta[]
}

model Cacada {
  id                     String   @id @default(cuid())
  videoReferenciaId      String
  canalReferenciaYtId    String?
  minGem                   Float
  exigirGem                Boolean  @default(true)
  exigirFiltroMetricas     Boolean  @default(false)
  capturaMinViews          Int      @default(0)
  capturaMaxInscritos      Int?
  capturaMinVideosCanal    Int      @default(0)
  capturaMaxVideosCanal    Int?
  capturaCombinacao        String   @default("E")
  status                 String   @default("ativa")
  // Acumulado: vídeos que passaram pela pipeline Gem nesta corrida (soma por passo).
  videosAnalisadosTotal  Int      @default(0)
  cursorRelated          String?
  videoIdsVistosJson     String   @default("[]")
  canalYoutubeVistosJson String   @default("[]")
  ultimoLog              String?
  criadoEm               DateTime @default(now())
  atualizadoEm           DateTime @updatedAt

  descobertas CacadaDescoberta[]
}

model CacadaDescoberta {
  id            String   @id @default(cuid())
  cacadaId      String
  canalId       String
  gemScore      Float
  videoOrigemId String?
  criadoEm      DateTime @default(now())

  cacada Cacada @relation(fields: [cacadaId], references: [id], onDelete: Cascade)
  canal  Canal  @relation(fields: [canalId], references: [id], onDelete: Cascade)

  @@unique([cacadaId, canalId])
}

model Video {
  id                  String    @id @default(cuid())
  youtubeId           String    @unique
  canalId             String
  titulo              String
  url                 String
  descricao           String?
  thumbnailUrl        String?
  thumbnailLocal      String?
  tags                String?
  views               Int?
  likes               Int?
  comentarios         Int?
  dataPublicacao      DateTime?
  duracaoSegundos     Int?
  viewsPorDia         Float?
  viewsPorInscrito    Float?
  transcript          String?
  hookTranscript      String?
  comentariosTopJson  String?
  usadoNoRaioX        Boolean   @default(false)
  ordemNoRaioX        Int?
  criadoEm            DateTime  @default(now())

  canal Canal @relation(fields: [canalId], references: [id], onDelete: Cascade)
}

model AnaliseDNA {
  id                   String   @id @default(cuid())
  canalId              String   @unique
  videosAnalisados     Int?
  videosIds            String?
  padraoTitulos        String?
  padraoThumbnails     String?
  padraoRoteiro        String?
  palavrasRecorrentes  String?
  temasRecorrentes     String?
  gatilhosDetectados   String?
  doresExploradas      String?
  tipoAudiencia        String?
  resumoEditorial      String?
  replicabilidade      String?
  replicabilidadeMotivo String?
  isFaceless           Boolean  @default(false)
  formulaTitulo        String?
  formulaVisual        String?
  formulaRoteiro       String?
  formulaHook          String?
  raw                  String?

  canal Canal @relation(fields: [canalId], references: [id], onDelete: Cascade)
}

model AnaliseDNAHistorico {
  id        String   @id @default(cuid())
  canalId   String
  snapshot  String
  criadoEm  DateTime @default(now())
}

model Projeto {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  status      String   @default("ativo")
  canalBaseId String?
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  canalBase Canal? @relation(fields: [canalBaseId], references: [id], onDelete: SetNull)
  ideias    Ideia[]
}

model Ideia {
  id         String   @id @default(cuid())
  projetoId  String
  titulo     String
  conteudo   String?
  status     String   @default("rascunho")
  criadoEm   DateTime @default(now())

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
}
